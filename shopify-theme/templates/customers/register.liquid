<section class="forma-shell">
  <h1 class="forma-title">{{ 'customer.create_account' | t }}</h1>
  {% form 'create_customer', class: 'forma-form' %}
    {{ form.errors | default_errors }}
    <input type="text" name="customer[first_name]" placeholder="{{ 'contact.name' | t }}">
    <input type="text" name="customer[last_name]" placeholder="{{ 'customer.last_name' | t }}">
    <input type="email" name="customer[email]" placeholder="{{ 'contact.email' | t }}" required>
    <input type="password" name="customer[password]" placeholder="{{ 'customer.password' | t }}" required>
    <button class="forma-button" type="submit">{{ 'customer.create_account' | t }}</button>
  {% endform %}
</section>
